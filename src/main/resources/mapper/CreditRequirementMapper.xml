<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.secondclass.mapper.CreditRequirementMapper">

    <select id="selectByCollegeAndGrade" resultType="com.secondclass.entity.CreditRequirement">
        SELECT * FROM credit_requirement
        WHERE college = #{college} AND grade = #{grade}
    </select>

</mapper>