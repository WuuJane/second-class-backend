<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.secondclass.mapper.SysOrganizationMapper">

    <select id="selectById" resultType="com.secondclass.entity.SysOrganization">
        SELECT * FROM sys_organization WHERE org_id = #{orgId}
    </select>

    <select id="selectAll" resultType="com.secondclass.entity.SysOrganization">
        SELECT * FROM sys_organization ORDER BY org_id
    </select>

    <insert id="insert" parameterType="com.secondclass.entity.SysOrganization" useGeneratedKeys="true" keyProperty="orgId">
        INSERT INTO sys_organization (org_name, org_level, college_name, org_type, auditor_org_id)
        VALUES (#{orgName}, #{orgLevel}, #{collegeName}, #{orgType}, #{auditorOrgId})
    </insert>

    <update id="update" parameterType="com.secondclass.entity.SysOrganization">
        UPDATE sys_organization
        <set>
            <if test="orgName != null">org_name = #{orgName},</if>
            <if test="orgLevel != null">org_level = #{orgLevel},</if>
            <if test="collegeName != null">college_name = #{collegeName},</if>
            <if test="orgType != null">org_type = #{orgType},</if>
            <if test="auditorOrgId != null">auditor_org_id = #{auditorOrgId},</if>
        </set>
        WHERE org_id = #{orgId}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_organization WHERE org_id = #{orgId}
    </delete>

</mapper>
